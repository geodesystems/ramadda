<services command="${service.soffice}"
	  icon="/icons/pdf.png">
  <service id="media_soffice_thumbnail" label="Make an image from CorelDraw"
	   outputToStderr="true"
	   >
    <arg value="--headless"/>
    <arg value="--convert-to"/>
    <arg value="png:draw_png_Export"/>
    <arg value="--outdir"/>
    <arg value="${workdir}"/>        
    <arg value="${entry.file}" type="entry" entryType="type_document_cdr"
	 matchPattern=".*\.cdr"
	 primary="true" copy="true" label="Input CDR File"></arg>
    <output type="type_image" pattern=".*\.png"/>
  </service>
    

  <service id="media_soffice_pdf" label="Make a PDF from CorelDraw"
	   outputToStderr="true"
	   >
    <arg value="--headless"/>
    <arg value="--convert-to"/>
    <arg value="pdf"/>
    <arg value="--outdir"/>
    <arg value="${workdir}"/>        
    <arg value="${entry.file}" type="entry" entryType="type_document_cdr"
	 matchPattern=".*\.cdr"
	 primary="true" copy="true" label="Input CDR File"></arg>
    <output type="type_document_pdf" pattern=".*\.pdf"/>
  </service>
    
  
</services>

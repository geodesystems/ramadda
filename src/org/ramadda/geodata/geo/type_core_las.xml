<!-- 
Since this is for import add a:
<import resource="type_core_las.xml"/>
into some types.xml file
-->
<types>
<type  name="type_core_las" 
 description="Log ASCII Standard" 
 handler="org.ramadda.geodata.geo.LasTypeHandler" 
 super="type_core_record_base" 
 supercategory="" 
 category="" 
pattern="(?i).*\.las"
>

<!-- Columns-->
<column  name="state"  label="State"  type="enumerationplus"  cansearch="true" showempty="false" />
<column  name="field"  label="Field"  type="enumerationplus"  cansearch="true" showempty="false" />
<property name="bubble">
<![CDATA[                                                                                                                           
+section  title="Log ASCII: {{name}}"                                                                                               
{{group}}                                                                                                                           
{{display_profile showMenu=true yAxisReverse=true marginTop=25                                                                      
profileMode="lines" indexField=".*depth.*"  #fields="#2,#3"}}                                                                       
]]></property>

<wikimacro name="core_profiles" label="Core Profiles" tags="forchild">
   <![CDATA[{{core_profiles showMenu=true yAxisReverse=true marginTop=25  profileMode=markers                                   
profileMode="lines" indexField=".*depth.*"  #fields="#2,#3"}}]]></wikimacro>
<!-- Properties-->
<property name="record.file.class" value="org.ramadda.data.point.text.CsvFile"/>
<property  name="record.pattern.date.format"  value="MM/dd/yy" />
<property  name="record.patterns"  value="field:FLD \.\s*([^\s]+)\s+,hole:WELL.\s*([^\s]+)\s*:WELL,state:STAT.\s*([^\s]+)\s*:STAT,top:STRT.FT\s*([\d.]+)\s+,bottom:STOP.FT\s*([\d.]+)\s+,date:DATE.\s*(\d\d/\d\d/\d\d)" />

<!-- SeeSV commands-->
<property  name="record.properties" ><![CDATA[
csvcommands1=-alldata,-startafter,~A,-delimiter,spaces
csvcommands2=-change,0-10,-999.*,NaN

picky=false

]]></property>
</type>
</types>

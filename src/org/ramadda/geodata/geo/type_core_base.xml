<!-- 
Since this is for import add a:
<import resource="type_core_base.xml"/>
into some types.xml file
-->
<types>
<type  name="type_core_base" 
 description="Core Base Type" 
 handler="org.ramadda.geodata.geo.CoreBaseTypeHandler" 
 supercategory="Geoscience" 
 category="Core Data" 
canbeindexed="false"
foruser="false"
metadata="geo_stratigraphy,geo_measurement"
>

<!-- Columns-->
<column  name="top_depth"  label="Top Depth"  type="double"  group="Core Metadata"  default="NaN" doinlineedit="true"   showinhtml="true" suffix="meters"  htmltemplate="${value unit=meters}   ${value decimals=3 showMissing=false   prefix=( suffix=&quot; feet) &quot; scale=3.28084}"  />
<column  name="bottom_depth"  label="Bottom Depth"  type="double"  default="NaN" doinlineedit="true"   showinhtml="true" suffix="meters"  htmltemplate="${value unit=meters}   ${value decimals=3 showMissing=false   prefix=( suffix=&quot; feet) &quot; scale=3.28084}"  />
<!-- Properties-->
<property name="record.file.class" value="org.ramadda.data.point.text.CsvFile"/>
<property  name="icon"  value="/geo/drilling-rig.png" />
<property  name="inheritlocationfromtype"  value="type_geo_site" />
<property  name="date.nullok"  value="true" />
<property  name="form.area.show"  value="false" />
<property  name="form.location.show"  value="true" />
</type>
</types>
